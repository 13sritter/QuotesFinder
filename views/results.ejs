<!DOCTYPE html>
<html>

<%- include("partials/header.ejs") %>

<body class="bodies">

    <h1 class="quoteHead"> Quotes Found </h1>

    <div class="forms">

    <% for (i of quotes) { %>

        <%= i.quoteId %> <%= i.quote %> <br>
        -<em>
            <a href="#" id="<%=i.authorId%>">
            <%= i.firstName%> <%= i.lastName %>
            </a>
        </em> <br> <br>

    <% } %>

    <!-- <div id="authorInfo"></div> -->

    <!-- Modal -->
    <div class="modal fade" id="authorModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
        <div class="modal-header">
            <h1 class="modal-title fs-5" id="exampleModalLabel">Author Information</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <div id="authorInfo"></div>
        </div>
        <div class="modal-footer" style="background-color: #8B5B29; color: #E3D4B9;">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="margin-right: auto; margin-left: auto;">Close</button>
            <!--<button type="button" class="btn btn-primary">Save changes</button>-->
        </div>
        </div>
    </div>
    </div>

    </div>

    <%- include("partials/footer.ejs")%>

    <script src="/js/scripts.js"></script>

</body>
</html>